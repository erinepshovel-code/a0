modules = ["nodejs-20", "web", "python-3.12", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt", "postgresql"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5904
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8001
externalPort = 3002

[env]
PORT = "5000"

[deployment]
deploymentTarget = "vm"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-dev.sh"
waitForPort = 5000

[agent]
integrations = ["javascript_database:1.0.0", "javascript_xai:1.0.0", "javascript_gemini_ai_integrations:2.0.0", "google-mail:1.0.0", "google-drive:1.0.0", "javascript_log_in_with_replit:2.0.0", "stripe:2.0.0", "github:1.0.0"]

[userenv]

[userenv.shared]
A0P_EMAIL = "wayseer00@gmail.com"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000
